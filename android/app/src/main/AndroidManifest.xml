        <meta-data
            android:name="android.support.customtabs.trusted.NAVIGATION_BAR_COLOR"
            android:value="#030514" />

        <meta-data
            android:name="android.support.customtabs.trusted.SPLASH_IMAGE_FADE_OUT_DURATION"
            android:value="1000" />

        <meta-data
            android:name="android.support.customtabs.trusted.FILE_PROVIDER_AUTHORITY"
            android:value="one.fundora.app.fileprovider" />

