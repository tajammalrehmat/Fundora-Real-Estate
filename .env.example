# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ==========================================
# OTP EMAIL CONFIGURATION (Required for Vercel Deployment to send Real OTPs)
# ==========================================

# OPTION A: RESEND API (Zero branding, completely free with custom domain, highly recommended)
# Get a free API key at https://resend.com and add it here.
# NOTE: In Vercel, you can just set RESEND_API_KEY (without VITE_ prefix) as a secret to keep it 100% safe.
RESEND_API_KEY=""
VITE_RESEND_API_KEY=""

# Tell the frontend that real email is active (hides the simulation OTP box on screen)
VITE_EMAIL_SERVICE_ACTIVE="true"

# The sender email. Default is fundora.one@gmail.com
RESEND_FROM_EMAIL="fundora.one@gmail.com"
VITE_RESEND_FROM_EMAIL="fundora.one@gmail.com"

# OPTION B: EMAILJS (Fallback)
# Configure EmailJS at https://emailjs.com and add credentials here.
VITE_EMAILJS_SERVICE_ID=""
VITE_EMAILJS_TEMPLATE_ID=""
VITE_EMAILJS_PUBLIC_KEY=""

# OPTION C: SECURE PROXY WEBHOOK (Perfect for GitHub Pages)
# Deploy a 100% free, unbranded Google Apps Script or Cloudflare Worker to send emails.
# This prevents GitHub from scanning/revoking keys since all keys are stored safely on the proxy server.
VITE_SECURE_PROXY_URL=""


